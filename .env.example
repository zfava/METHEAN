# ── METHEAN Environment Configuration ──
# Copy this to .env and fill in your values. Never commit .env to version control.

# ── Application ──
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Database ──
DATABASE_URL=postgresql+asyncpg://methean:methean_dev@postgres:5432/methean
DATABASE_URL_SYNC=postgresql://methean:methean_dev@postgres:5432/methean

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Auth ──
JWT_SECRET=generate-a-random-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI ──
AI_API_KEY=
AI_FALLBACK_API_KEY=
AI_PRIMARY_MODEL=claude-sonnet-4-20250514
AI_FALLBACK_MODEL=gpt-4o-mini
AI_MOCK_ENABLED=true
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ── S3-compatible storage ──
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=methean-artifacts

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── FSRS / Retention ──
MASTERY_THRESHOLD=0.8
DECAY_RETRIEVABILITY_THRESHOLD=0.5
DECAY_CRON_HOUR=2
DECAY_CRON_MINUTE=0
DECAY_BATCH_SIZE=500

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
