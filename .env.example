# ── METHEAN Environment Configuration ──
# Copy this to .env and fill in your values. Never commit .env to version control.
#
# For Docker Compose: use service names (postgres, redis, minio)
# For local dev:      use localhost

# ── Application ──
APP_ENV=development            # development | staging | production
APP_DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Database ──
# Docker:  postgresql+asyncpg://methean:methean_dev@postgres:5432/methean
# Local:   postgresql+asyncpg://methean:methean_dev@localhost:5432/methean
DATABASE_URL=postgresql+asyncpg://methean:methean_dev@localhost:5432/methean
DATABASE_URL_SYNC=postgresql://methean:methean_dev@localhost:5432/methean

# ── Redis ──
# Docker:  redis://redis:6379/0
# Local:   redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Auth ──
JWT_SECRET=change-me-to-a-random-64-char-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI (optional — runs in mock mode if keys not set) ──
AI_API_KEY=                    # Anthropic API key for real AI responses
AI_FALLBACK_API_KEY=           # OpenAI API key (optional fallback)
# Primary model: Claude Opus 4.6 (highest intelligence, used for all family-facing AI)
AI_PRIMARY_MODEL=claude-opus-4-6
# Standard model: Claude Sonnet 4.6 (used for background batch tasks)
AI_STANDARD_MODEL=claude-sonnet-4-6
# Light model: Claude Haiku 4.5 (available as family-selectable tier)
AI_LIGHT_MODEL=claude-haiku-4-5-20251001
AI_FALLBACK_MODEL=gpt-4o-mini
AI_MOCK_ENABLED=true           # Set to false when using real API keys
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ── S3-compatible storage ──
# Docker:  http://minio:9000
# Local:   http://localhost:9000
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=methean-artifacts

# ── Celery ──
# Docker:  redis://redis:6379/1
# Local:   redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── FSRS / Retention ──
MASTERY_THRESHOLD=0.8
DECAY_RETRIEVABILITY_THRESHOLD=0.5
DECAY_CRON_HOUR=2
DECAY_CRON_MINUTE=0
DECAY_BATCH_SIZE=500

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
