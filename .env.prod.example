# ══════════════════════════════════════════════════
# METHEAN Production Environment Variables
# Copy to .env.prod and fill in real values.
# NEVER commit .env.prod to version control.
# ══════════════════════════════════════════════════

# ══════════════ APPLICATION ══════════════
APP_ENV=production
APP_DEBUG=false
LOG_LEVEL=INFO
# Comma-separated allowed origins for CORS. Must include your production domain.
CORS_ORIGINS=["https://methean.app","https://www.methean.app"]
# Public-facing URL of the frontend (used for email links, Stripe redirects)
APP_URL=https://methean.app

# ══════════════ DATABASE ══════════════
# PostgreSQL credentials. Use a strong, unique password.
DB_USER=methean_prod
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=methean_prod
# Async driver for FastAPI/SQLAlchemy
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}
# Sync driver for Alembic migrations
DATABASE_URL_SYNC=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# ══════════════ REDIS ══════════════
# Redis for caching, rate limiting, and Celery broker
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ══════════════ AUTH (REQUIRED) ══════════════
# Must be cryptographically random, minimum 64 characters.
# Generate with: openssl rand -base64 64 | tr -d '\n'
# Or run: ./scripts/generate-secrets.sh
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
# Set to the OLD JWT_SECRET when rotating keys. Empty on first deploy.
PREVIOUS_JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ══════════════ AI PROVIDERS ══════════════
# Anthropic Claude API key (primary AI provider)
# Get from: https://console.anthropic.com/settings/keys
AI_API_KEY=sk-ant-CHANGE_ME
# OpenAI API key (fallback provider, optional)
# Get from: https://platform.openai.com/api-keys
AI_FALLBACK_API_KEY=
# Primary model: Claude Opus 4.6 (highest intelligence, used for all family-facing AI)
AI_PRIMARY_MODEL=claude-opus-4-6
# Standard model: Claude Sonnet 4.6 (used for background batch tasks)
AI_STANDARD_MODEL=claude-sonnet-4-6
# Light model: Claude Haiku 4.5 (available as family-selectable tier)
AI_LIGHT_MODEL=claude-haiku-4-5-20251001
# Fallback model: OpenAI (used only if Claude is unavailable)
AI_FALLBACK_MODEL=gpt-4o-mini
# Set to false in production to use real AI providers
AI_MOCK_ENABLED=false
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.7

# ══════════════ S3 / OBJECT STORAGE ══════════════
# MinIO or AWS S3 compatible endpoint for artifact storage
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_BUCKET_NAME=methean-artifacts

# ══════════════ STRIPE BILLING ══════════════
# Get from: https://dashboard.stripe.com/apikeys (LIVE mode, not test)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
# Get from: https://dashboard.stripe.com/webhooks (endpoint secret)
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# Get from: https://dashboard.stripe.com/products (the $99/month price ID)
STRIPE_PRICE_ID=price_CHANGE_ME
STRIPE_TRIAL_DAYS=14

# ══════════════ EMAIL (RESEND) ══════════════
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=METHEAN <notifications@methean.app>

# ══════════════ PUSH NOTIFICATIONS (FCM) ══════════════
# Firebase project ID from https://console.firebase.google.com
FCM_PROJECT_ID=
# Path to service account JSON file, or the JSON string inline
FCM_SERVICE_ACCOUNT_JSON=

# ══════════════ MONITORING ══════════════
# Sentry DSN for error tracking. Empty = disabled.
# Get from: https://sentry.io/settings/projects/
SENTRY_DSN=

# ══════════════ FRONTEND ══════════════
# The API URL the frontend uses to reach the backend
NEXT_PUBLIC_API_URL=https://methean.app/api/v1

# ══════════════ FSRS / RETENTION (OPTIONAL) ══════════════
# Leave defaults unless you have custom FSRS weights
MASTERY_THRESHOLD=0.8
DECAY_RETRIEVABILITY_THRESHOLD=0.5
DECAY_CRON_HOUR=2
DECAY_CRON_MINUTE=0
DECAY_BATCH_SIZE=500
