# Android Release Signing Configuration
# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties to git.
#
# Generate keystore:
#   keytool -genkey -v -keystore methean-release.keystore \
#     -alias methean -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=methean-release.keystore
storePassword=
keyAlias=methean
keyPassword=
