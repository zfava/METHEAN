# Monitoring
SENTRY_DSN=

# Push Notifications
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# AI (mock enabled by default in staging compose)
AI_API_KEY=
AI_FALLBACK_API_KEY=

# Email (optional for staging)
RESEND_API_KEY=
