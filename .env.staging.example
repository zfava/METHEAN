# METHEAN Staging Environment
# Copy to .env.staging and fill in real values

JWT_SECRET=staging-secret-change-in-real-staging-min-64-chars-xxxxxxxxxxxxxxxx
PREVIOUS_JWT_SECRET=

# Stripe (use test keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Monitoring
SENTRY_DSN=

# Push Notifications
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=

# AI (mock enabled by default in staging compose)
AI_API_KEY=
AI_FALLBACK_API_KEY=
# Primary model: Claude Opus 4.6 (highest intelligence, used for all family-facing AI)
AI_PRIMARY_MODEL=claude-opus-4-6
# Standard model: Claude Sonnet 4.6 (used for background batch tasks)
AI_STANDARD_MODEL=claude-sonnet-4-6
# Light model: Claude Haiku 4.5 (available as family-selectable tier)
AI_LIGHT_MODEL=claude-haiku-4-5-20251001
AI_FALLBACK_MODEL=gpt-4o-mini

# Email (optional for staging)
RESEND_API_KEY=
